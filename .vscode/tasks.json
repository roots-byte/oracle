{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build Oracle",
            "type": "shell",
            "command": "gcc",
            "args": [
                "-std=c99",
                "-g3",
                "-O0",
                "-I", "header",
                "oracle.c",
                "oci.lib",
                "-o", "oracle.exe"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ],
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        }
    ]
}
